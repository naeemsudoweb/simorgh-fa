# ================================================================
# Simorgh FC — environment configuration
# ================================================================
# 1. Copy this file to ".env"        (cp .env.example .env)
# 2. Fill in the values below.
# 3. Never commit your real ".env" file to git or share it with anyone.
# ================================================================

# A long random string used to sign session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Admin panel login username
ADMIN_USERNAME=admin

# Admin panel login password — stored as a HASH, never as plain text.
# Generate this by running:  python generate_password_hash.py
ADMIN_PASSWORD_HASH=

# Set to "true" only while developing locally. Must be "false" (or unset)
# on any server that real people can reach — debug mode leaks source code
# and lets visitors run arbitrary Python if it's left on in production.
FLASK_DEBUG=false
